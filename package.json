{
  "name": "zavrsi-mi",
  "version": "1.0.0",
  "description": "Završi Mi - Platforma za lokalne usluge",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-windows.ps1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
